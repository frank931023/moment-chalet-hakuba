# ================================
# App
# ================================
NODE_ENV=development
VITE_APP_URL=http://localhost:5173

# ================================
# Supabase
# ================================
# 從 Supabase Dashboard > Settings > API 取得
# https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key   # 僅後端 Edge Functions 使用，勿暴露前端

# ================================
# PayPal
# ================================
# 從 PayPal Developer Dashboard 取得
# https://developer.paypal.com/dashboard/
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id          # 前端用（公開）
PAYPAL_CLIENT_SECRET=your_paypal_client_secret        # 僅 Edge Functions 使用
PAYPAL_MODE=sandbox                                   # sandbox | live
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com  # sandbox: api-m.sandbox.paypal.com | live: api-m.paypal.com

# ================================
# Google Maps（地圖嵌入）
# ================================
# 從 Google Cloud Console 取得，需啟用 Maps JavaScript API
# https://console.cloud.google.com/
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# 若改用 Leaflet + OpenStreetMap 則不需要此 key

# ================================
# Email 通知
# ================================
# 選項 A：Resend（推薦，簡單易用）
# https://resend.com/
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=no-reply@your-domain.com

# 選項 B：SMTP（Gmail / Outlook 等）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_smtp_app_password

# ================================
# iCal Sync
# ================================
# 各民宿的 iCal URL（從 Airbnb / Booking.com 匯出）
ICAL_URL_PROPERTY_1=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_2=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_3=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_4=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_5=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_6=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_7=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_8=https://www.airbnb.com/calendar/ical/xxxxx.ics
ICAL_URL_PROPERTY_9=https://www.airbnb.com/calendar/ical/xxxxx.ics

# ================================
# AI Chatbot（民宿問答機器人）
# ================================
# 選項 A：OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o   # gpt-4o | gpt-3.5-turbo

# 選項 B：Google Gemini
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-pro

# ================================
# Azure（部署用）
# ================================
# Azure Static Web Apps deployment token（CI/CD 用）
AZURE_STATIC_WEB_APPS_API_TOKEN=your_azure_swa_token

# Azure Functions（iCal 定時同步 + 費用資料抓取）
AZURE_FUNCTION_SUPABASE_URL=https://your-project.supabase.co
AZURE_FUNCTION_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Azure Cost Management API（費用監控）
# 需在 Azure Portal 建立 Service Principal 並授予 Cost Management Reader 角色
# https://learn.microsoft.com/en-us/azure/cost-management-billing/costs/quick-acm-cost-analysis
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_service_principal_client_id
AZURE_CLIENT_SECRET=your_azure_service_principal_client_secret
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id

# Azure Monitor / Logic Apps（警示通知）
# Logic App 的 HTTP trigger URL（由 Logic App 建立後取得）
AZURE_LOGIC_APP_WEBHOOK_URL=https://prod-xx.eastasia.logic.azure.com/workflows/xxx/triggers/manual/paths/invoke

# ================================
# Supabase Storage（圖片上傳）
# ================================
# bucket 名稱，在 Supabase Dashboard 建立
SUPABASE_STORAGE_BUCKET=property-images
